# Gemini API Key for Triage Engine
GEMINI_API_KEY=your_gemini_api_key_here

# Fivetran Credentials
FIVETRAN_API_KEY=your_fivetran_api_key_here
FIVETRAN_API_SECRET=your_fivetran_api_secret_here

# Google Cloud Project ID
GCP_PROJECT_ID=your_gcp_project_id_here

# Slack Webhook URL for Notifications and HITL
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Base64 Encoded Fivetran API Key (used in some legacy connectors)
Base64_Encoded_apiKey=your_base64_encoded_apikey_here
